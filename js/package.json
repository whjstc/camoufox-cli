{
  "name": "camoufox-cli",
  "version": "0.1.6",
  "description": "Anti-detect headless browser automation CLI for AI agents, powered by Camoufox",
  "type": "module",
  "bin": {
    "camoufox-cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "cp ../README.md . && npm run build"
  },
  "keywords": [
    "browser",
    "automation",
    "anti-detect",
    "camoufox",
    "ai-agent",
    "headless"
  ],
  "author": "Benn Huang",
  "license": "MIT",
  "repository": "https://github.com/Bin-Huang/camoufox-cli",
  "dependencies": {
    "camoufox-js": "^0.8.5",
    "playwright-core": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "scripts"
  ]
}
